#!/bin/bash
# validate-plugin - Verify a dispatcher plugin meets contribution requirements
#
# Usage:
#   tools/validate-plugin <plugin-path>
#
# Examples:
#   tools/validate-plugin agent-scripts/linux-audit
#   tools/validate-plugin auth/htpasswd
#   tools/validate-plugin dispatcher-manager/rapidoc
#
# Exit codes:
#   0   all checks passed
#   1   one or more checks failed

set -euo pipefail

# --- helpers -----------------------------------------------------------------

PASS=0
FAIL=0

pass() { echo "  PASS  $1"; PASS=$((PASS + 1)); }
fail() { echo "  FAIL  $1"; FAIL=$((FAIL + 1)); }

check_file_exists() {
    local path="$1" label="$2"
    if [[ -f "$path" ]]; then
        pass "$label exists"
    else
        fail "$label missing: $path"
    fi
}

check_heading() {
    local file="$1" heading="$2"
    if grep -q "^## ${heading}$" "$file" 2>/dev/null; then
        pass "README has '## ${heading}'"
    else
        fail "README missing '## ${heading}'"
    fi
}

check_json_valid() {
    local file="$1" label="$2"
    if python3 -c "import json,sys; json.load(open('$file'))" 2>/dev/null; then
        pass "$label is valid JSON"
    else
        fail "$label is not valid JSON"
    fi
}

check_json_field() {
    local file="$1" field="$2"
    if python3 -c "import json,sys; d=json.load(open('$file')); sys.exit(0 if '$field' in d else 1)" 2>/dev/null; then
        pass "sbom.json has field '$field'"
    else
        fail "sbom.json missing field '$field'"
    fi
}

# --- entrypoint --------------------------------------------------------------

main() {
    local plugin_path="${1:-}"

    if [[ -z "$plugin_path" ]]; then
        echo "Usage: tools/validate-plugin <plugin-path>" >&2
        exit 1
    fi

    # Normalise: strip trailing slash
    plugin_path="${plugin_path%/}"

    if [[ ! -d "$plugin_path" ]]; then
        echo "Error: '$plugin_path' is not a directory" >&2
        exit 1
    fi

    # Detect category from path
    local category
    case "$plugin_path" in
        agent-scripts/*) category="agent-scripts" ;;
        auth/*)          category="auth" ;;
        dispatcher-manager/*) category="dispatcher-manager" ;;
        */agent-scripts/*) category="agent-scripts" ;;
        */auth/*)          category="auth" ;;
        */dispatcher-manager/*) category="dispatcher-manager" ;;
        *)
            echo "Error: cannot determine category from path '$plugin_path'" >&2
            echo "  Path must contain agent-scripts/, auth/, or dispatcher-manager/" >&2
            exit 1
            ;;
    esac

    local plugin_name
    plugin_name="$(basename "$plugin_path")"

    echo "Validating plugin: $plugin_name (category: $category)"
    echo "Path: $plugin_path"
    echo ""

    # --- Universal checks ----------------------------------------------------

    echo "[ Required files ]"
    check_file_exists "$plugin_path/README.md"  "README.md"
    check_file_exists "$plugin_path/LICENSE"    "LICENSE"
    check_file_exists "$plugin_path/sbom.json"  "sbom.json"
    echo ""

    echo "[ README sections ]"
    local readme="$plugin_path/README.md"
    if [[ -f "$readme" ]]; then
        check_heading "$readme" "Purpose"
        check_heading "$readme" "Dependencies"
        check_heading "$readme" "Installation"
        check_heading "$readme" "Examples"
        check_heading "$readme" "Limitations"

        case "$category" in
            agent-scripts)
                check_heading "$readme" "scripts.conf"
                check_heading "$readme" "Subcommands"
                ;;
            auth)
                check_heading "$readme" "Configuration"
                check_heading "$readme" "Exit codes"
                ;;
            dispatcher-manager)
                check_heading "$readme" "Configuration"
                ;;
        esac
    fi
    echo ""

    echo "[ sbom.json ]"
    if [[ -f "$plugin_path/sbom.json" ]]; then
        check_json_valid "$plugin_path/sbom.json" "sbom.json"
        check_json_field "$plugin_path/sbom.json" "bomFormat"
        check_json_field "$plugin_path/sbom.json" "specVersion"
        check_json_field "$plugin_path/sbom.json" "components"
    fi
    echo ""

    # --- Category-specific checks --------------------------------------------

    case "$category" in
        agent-scripts)
            validate_agent_script "$plugin_path" "$plugin_name"
            ;;
        auth)
            validate_auth_hook "$plugin_path" "$plugin_name"
            ;;
        dispatcher-manager)
            validate_manager "$plugin_path" "$plugin_name"
            ;;
    esac

    # --- Summary --------------------------------------------------------------

    echo ""
    echo "Results: $PASS passed, $FAIL failed"

    if [[ $FAIL -gt 0 ]]; then
        echo "INVALID - fix the above failures before submitting"
        exit 1
    else
        echo "VALID"
        exit 0
    fi
}

# --- Category validators -----------------------------------------------------

validate_agent_script() {
    local plugin_path="$1" plugin_name="$2"

    # Locate the script file - must be the only .sh file, or named after plugin
    local script_file=""
    if [[ -f "$plugin_path/${plugin_name}.sh" ]]; then
        script_file="$plugin_path/${plugin_name}.sh"
    else
        # Fall back to any single .sh file
        local sh_files
        mapfile -t sh_files < <(find "$plugin_path" -maxdepth 1 -name "*.sh" 2>/dev/null)
        if [[ ${#sh_files[@]} -eq 1 ]]; then
            script_file="${sh_files[0]}"
        fi
    fi

    echo "[ Agent script ]"

    if [[ -z "$script_file" ]]; then
        fail "No script file found (expected ${plugin_name}.sh or single .sh file)"
        echo ""
        return
    fi

    local script_basename
    script_basename="$(basename "$script_file")"
    pass "Script file found: $script_basename"

    # Shebang
    local first_line
    first_line="$(head -1 "$script_file")"
    if [[ "$first_line" =~ ^#! ]]; then
        pass "Script has shebang: $first_line"
    else
        fail "Script missing shebang line"
    fi

    # Executable
    if [[ -x "$script_file" ]]; then
        pass "Script is executable"
    else
        fail "Script is not executable (run: chmod +x $script_file)"
    fi

    # Script name matches allowlist pattern
    local script_name="${script_basename%.sh}"
    if [[ "$script_name" =~ ^[a-zA-Z0-9_-]+$ ]]; then
        pass "Script name '$script_name' matches allowlist pattern [\\w-]+"
    else
        fail "Script name '$script_name' contains characters not allowed in scripts.conf"
    fi

    # scripts.conf snippet present in README
    if grep -q 'scripts\.conf' "$plugin_path/README.md" 2>/dev/null; then
        pass "README references scripts.conf"
    else
        fail "README does not reference scripts.conf"
    fi

    # Live execution: no args should print usage to stderr and exit non-zero
    echo ""
    echo "[ Live execution ]"
    local exit_code=0
    local output
    output="$("$script_file" 2>&1)" || exit_code=$?

    if [[ $exit_code -ne 0 ]]; then
        pass "Script exits non-zero ($exit_code) when called with no args"
    else
        fail "Script exits 0 when called with no args (expected usage error)"
    fi

    if [[ -n "$output" ]]; then
        pass "Script produces output when called with no args (usage text)"
    else
        fail "Script produces no output when called with no args (expected usage text)"
    fi

    echo ""
}

validate_auth_hook() {
    local plugin_path="$1" plugin_name="$2"

    # Locate hook executable
    local hook_file=""
    if [[ -f "$plugin_path/${plugin_name}" ]]; then
        hook_file="$plugin_path/${plugin_name}"
    elif [[ -f "$plugin_path/auth-hook" ]]; then
        hook_file="$plugin_path/auth-hook"
    fi

    echo "[ Auth hook ]"

    if [[ -z "$hook_file" ]]; then
        fail "No hook file found (expected ${plugin_name} or auth-hook)"
        echo ""
        return
    fi

    pass "Hook file found: $(basename "$hook_file")"

    if [[ -x "$hook_file" ]]; then
        pass "Hook is executable"
    else
        fail "Hook is not executable"
    fi

    local first_line
    first_line="$(head -1 "$hook_file")"
    if [[ "$first_line" =~ ^#! ]]; then
        pass "Hook has shebang"
    else
        fail "Hook missing shebang"
    fi

    # Live: empty stdin should not crash (exit 1 is acceptable, not crash)
    echo ""
    echo "[ Live execution ]"
    local exit_code=0
    echo "" | "$hook_file" >/dev/null 2>&1 || exit_code=$?

    if [[ $exit_code -le 3 ]]; then
        pass "Hook exits with valid code ($exit_code) on empty stdin"
    else
        fail "Hook exited $exit_code on empty stdin (expected 0-3)"
    fi

    # Synthetic authorised payload
    local payload='{"action":"ping","script":"","hosts":["test-host"],"args":[],"username":"validator","token":"","source_ip":"127.0.0.1","timestamp":"2025-01-01T00:00:00Z"}'
    exit_code=0
    echo "$payload" | "$hook_file" >/dev/null 2>&1 || exit_code=$?

    if [[ $exit_code -le 3 ]]; then
        pass "Hook exits with valid code ($exit_code) on synthetic ping payload"
    else
        fail "Hook crashed (exit $exit_code) on synthetic ping payload"
    fi

    echo ""
}

validate_manager() {
    local plugin_path="$1" plugin_name="$2"

    echo "[ Manager plugin ]"

    # At least one non-README, non-meta file must exist
    local plugin_files
    mapfile -t plugin_files < <(find "$plugin_path" -maxdepth 1 -type f \
        ! -name "README.md" ! -name "LICENSE" ! -name "sbom.json" 2>/dev/null)

    if [[ ${#plugin_files[@]} -gt 0 ]]; then
        pass "Plugin contains ${#plugin_files[@]} file(s) beyond required metadata"
    else
        fail "Plugin contains no files beyond README.md, LICENSE, sbom.json"
    fi

    echo ""
}

main "$@"
