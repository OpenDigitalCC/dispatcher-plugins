#!/usr/bin/perl
use strict;
use warnings;

use Getopt::Long qw(GetOptionsFromArray);
use HTTP::Tiny   ();
use JSON::PP     qw(encode_json decode_json);

our $VERSION = '0.1.0';

# ---------------------------------------------------------------------------
# Defaults
# ---------------------------------------------------------------------------

my $DEFAULT_URL = 'http://localhost:7445';
my $CONFIG_FILE = "/root/.ctrl-exec-cli.conf";

# ---------------------------------------------------------------------------
# Entry point
# ---------------------------------------------------------------------------

main() unless caller;

sub main {
    my %global;

    Getopt::Long::Configure('pass_through', 'no_auto_abbrev');
    GetOptionsFromArray(
        \@ARGV,
        'url=s'      => \$global{url},
        'token=s'    => \$global{token},
        'username=s' => \$global{username},
        'json'       => \$global{json},
        'help|h'     => \$global{help},
        'version|V'  => \$global{version},
    );

    if ($global{version}) {
        print "ctrl-exec-cli $VERSION\n";
        exit 0;
    }

    my $cmd = shift @ARGV // '';

    if ($global{help} && !$cmd) {
        print usage_main();
        exit 0;
    }

    if (!$cmd) {
        print STDERR usage_main();
        exit 1;
    }

    my $cfg = load_config($CONFIG_FILE);
    my $ctx = build_context(\%global, $cfg);

    my %commands = (
        'health'    => \&cmd_health,
        'ping'      => \&cmd_ping,
        'run'       => \&cmd_run,
        'status'    => \&cmd_status,
        'discovery' => \&cmd_discovery,
    );

    my $handler = $commands{$cmd}
        or die "Unknown command '$cmd'\nRun ctrl-exec-cli --help for usage.\n";

    $handler->($ctx, @ARGV);
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

sub cmd_health {
    my ($ctx, @args) = @_;

    my %opts;
    GetOptionsFromArray(\@args, 'help|h' => \$opts{help})
        or die usage_health();
    print usage_health() and exit 0 if $opts{help};

    my $data = api_get($ctx, '/health');

    if ($ctx->{json}) {
        print encode_json($data), "\n";
        return;
    }

    if ($data->{ok}) {
        printf "%-12s %s\n", 'STATUS',  'ok';
        printf "%-12s %s\n", 'VERSION', $data->{version} // '?';
    }
    else {
        die_error($data);
    }
}

sub cmd_ping {
    my ($ctx, @args) = @_;

    my %opts;
    GetOptionsFromArray(\@args,
        'json'   => \$opts{json},
        'help|h' => \$opts{help},
    ) or die usage_ping();
    print usage_ping() and exit 0 if $opts{help};

    $ctx->{json} = 1 if $opts{json};

    die usage_ping() unless @args;

    my $data = api_post($ctx, '/ping', {
        hosts    => \@args,
        username => $ctx->{username},
        token    => $ctx->{token},
    });

    die_error($data) unless $data->{ok};

    if ($ctx->{json}) {
        print encode_json($data), "\n";
        return;
    }

    my @results = @{ $data->{results} // [] };
    printf "%-20s %-8s %-10s %-30s %s\n",
        'HOST', 'STATUS', 'RTT', 'CERT EXPIRY', 'VERSION';
    print '-' x 78, "\n";

    my $any_error = 0;
    for my $r (@results) {
        if (($r->{status} // '') eq 'ok') {
            printf "%-20s %-8s %-10s %-30s %s\n",
                $r->{host},
                'ok',
                $r->{rtt}     // '-',
                $r->{expiry}  // '-',
                $r->{version} // '-';
        }
        else {
            printf "%-20s %-8s %-10s %s\n",
                $r->{host},
                'error',
                $r->{rtt}   // '-',
                $r->{error} // 'unknown error';
            $any_error = 1;
        }
    }

    exit 1 if $any_error;
}

sub cmd_run {
    my ($ctx, @args) = @_;

    # Split on -- before GetOptionsFromArray, which would otherwise consume it
    my (@before_sep, @script_args);
    my $found_sep = 0;
    for my $i (0 .. $#args) {
        if ($args[$i] eq '--') {
            @before_sep  = @args[0 .. $i - 1];
            @script_args = @args[$i + 1 .. $#args];
            $found_sep   = 1;
            last;
        }
    }
    @before_sep = @args unless $found_sep;

    my %opts;
    GetOptionsFromArray(\@before_sep,
        'script=s' => \$opts{script},
        'async'    => \$opts{async},
        'json'     => \$opts{json},
        'help|h'   => \$opts{help},
    ) or die usage_run();
    print usage_run() and exit 0 if $opts{help};

    $ctx->{json} = 1 if $opts{json};

    # Remaining elements after option parsing are hosts
    my @hosts = @before_sep;

    die usage_run() unless @hosts && $opts{script};

    my $data = api_post($ctx, '/run', {
        hosts    => \@hosts,
        script   => $opts{script},
        args     => \@script_args,
        username => $ctx->{username},
        token    => $ctx->{token},
    });

    if (!$data->{ok}) {
        if (($data->{code} // 0) == 4) {
            my @conflicts = @{ $data->{conflicts} // [] };
            die "Lock conflict - script already running on: "
                . join(', ', @conflicts) . "\n";
        }
        die_error($data);
    }

    # --async: print reqid and exit immediately
    if ($opts{async}) {
        my $reqid = $data->{reqid} // '';
        die "Error: server did not return a reqid\n" unless $reqid;
        if ($ctx->{json}) {
            print encode_json({ reqid => $reqid }), "\n";
        }
        else {
            print "$reqid\n";
        }
        return;
    }

    if ($ctx->{json}) {
        print encode_json($data), "\n";
        return;
    }

    # Print top-level reqid for log correlation
    printf "reqid: %s\n", $data->{reqid} // '-';
    print "\n";

    my @results  = @{ $data->{results} // [] };
    my $any_fail = 0;

    for my $r (@results) {
        my $exit   = $r->{exit} // -1;
        my $status = $exit == 0  ? 'ok'
                   : $exit == -1 ? 'error'
                   :               "exit:$exit";

        printf "==> %-20s  [%s  %s]\n",
            $r->{host},
            $status,
            $r->{rtt} // '-';

        if (length($r->{stdout} // '')) {
            print $r->{stdout};
            print "\n" unless $r->{stdout} =~ /\n$/;
        }
        if (length($r->{stderr} // '')) {
            print STDERR $r->{stderr};
            print STDERR "\n" unless $r->{stderr} =~ /\n$/;
        }
        if ($exit != 0) {
            print STDERR "    error: $r->{error}\n" if $r->{error};
            $any_fail = 1;
        }
    }

    exit 1 if $any_fail;
}

sub cmd_status {
    my ($ctx, @args) = @_;

    my %opts;
    GetOptionsFromArray(\@args,
        'json'   => \$opts{json},
        'help|h' => \$opts{help},
    ) or die usage_status();
    print usage_status() and exit 0 if $opts{help};

    $ctx->{json} = 1 if $opts{json};

    my $reqid = shift @args
        or die usage_status();

    # reqid is alphanumeric - reject obvious garbage before hitting the API
    die "Error: invalid reqid '$reqid'\n"
        unless $reqid =~ /^[a-f0-9]+$/i;

    my $data = api_get($ctx, "/status/$reqid");

    # 404 means not found or expired - report clearly and exit 1
    if (!$data->{ok}) {
        my $msg = $data->{error} // 'not found';
        $msg .= ": $data->{detail}" if $data->{detail};
        die "Error: $msg\n";
    }

    if ($ctx->{json}) {
        print encode_json($data), "\n";
        return;
    }

    printf "reqid:     %s\n",  $data->{reqid}     // '-';
    printf "script:    %s\n",  $data->{script}    // '-';
    printf "hosts:     %s\n",  join(', ', @{ $data->{hosts} // [] });
    printf "completed: %s\n",  _format_ts($data->{completed});
    print  "\n";

    my @results  = @{ $data->{results} // [] };
    my $any_fail = 0;

    for my $r (@results) {
        my $exit   = $r->{exit} // -1;
        my $status = $exit == 0  ? 'ok'
                   : $exit == -1 ? 'error'
                   :               "exit:$exit";

        printf "==> %-20s  [%s  %s]\n",
            $r->{host},
            $status,
            $r->{rtt} // '-';

        if (length($r->{stdout} // '')) {
            print $r->{stdout};
            print "\n" unless $r->{stdout} =~ /\n$/;
        }
        if (length($r->{stderr} // '')) {
            print STDERR $r->{stderr};
            print STDERR "\n" unless $r->{stderr} =~ /\n$/;
        }
        if ($exit != 0) {
            print STDERR "    error: $r->{error}\n" if $r->{error};
            $any_fail = 1;
        }
    }

    exit 1 if $any_fail;
}

sub _format_ts {
    my ($epoch) = @_;
    return '-' unless $epoch;
    my @t = localtime($epoch);
    return sprintf '%04d-%02d-%02d %02d:%02d:%02d',
        $t[5] + 1900, $t[4] + 1, $t[3], $t[2], $t[1], $t[0];
}

sub cmd_discovery {
    my ($ctx, @args) = @_;

    my %opts;
    GetOptionsFromArray(\@args,
        'scripts' => \$opts{scripts},
        'json'    => \$opts{json},
        'help|h'  => \$opts{help},
    ) or die usage_discovery();
    print usage_discovery() and exit 0 if $opts{help};

    $ctx->{json} = 1 if $opts{json};

    # Remaining args are optional host filters
    my @hosts = @args;

    my $data;
    if (@hosts) {
        $data = api_post($ctx, '/discovery', {
            hosts    => \@hosts,
            username => $ctx->{username},
            token    => $ctx->{token},
        });
    }
    else {
        $data = api_get($ctx, '/discovery');
    }

    die_error($data) unless $data->{ok};

    if ($ctx->{json}) {
        print encode_json($data), "\n";
        return;
    }

    my %hosts = %{ $data->{hosts} // {} };

    if (!%hosts) {
        print "No agents found.\n";
        return;
    }

    if ($opts{scripts}) {
        # Verbose: one block per host with script list
        for my $hostname (sort keys %hosts) {
            my $h = $hosts{$hostname};
            if (($h->{status} // '') ne 'ok') {
                printf "%s  error: %s\n\n",
                    $hostname, $h->{error} // 'unreachable';
                next;
            }
            printf "%s  (v%s)\n", $hostname, $h->{version} // '?';
            my @scripts = @{ $h->{scripts} // [] };
            if (@scripts) {
                for my $s (sort { $a->{name} cmp $b->{name} } @scripts) {
                    my $flag = ($s->{executable} // 1) ? '' : '  [not executable]';
                    printf "  %-25s %s%s\n",
                        $s->{name}, $s->{path} // '', $flag;
                }
            }
            else {
                print "  (no scripts)\n";
            }
            print "\n";
        }
    }
    else {
        # Summary table
        printf "%-20s %-8s %-10s %s\n",
            'HOST', 'STATUS', 'VERSION', 'SCRIPTS';
        print '-' x 55, "\n";
        for my $hostname (sort keys %hosts) {
            my $h      = $hosts{$hostname};
            my $status = $h->{status} // 'error';
            if ($status eq 'ok') {
                printf "%-20s %-8s %-10s %d\n",
                    $hostname,
                    'ok',
                    $h->{version} // '-',
                    scalar @{ $h->{scripts} // [] };
            }
            else {
                printf "%-20s %-8s %s\n",
                    $hostname, 'error', $h->{error} // '-';
            }
        }
    }
}

# ---------------------------------------------------------------------------
# HTTP helpers
# ---------------------------------------------------------------------------

sub api_get {
    my ($ctx, $path) = @_;
    my $ua  = _make_ua();
    my $res = $ua->get($ctx->{url} . $path, {
        headers => { 'Accept' => 'application/json' },
    });
    return _handle_response($res);
}

sub api_post {
    my ($ctx, $path, $body) = @_;
    my $ua  = _make_ua();
    my $res = $ua->post($ctx->{url} . $path, {
        headers => {
            'Content-Type' => 'application/json',
            'Accept'       => 'application/json',
        },
        content => encode_json($body),
    });
    return _handle_response($res);
}

sub _make_ua {
    return HTTP::Tiny->new(
        agent   => "ctrl-exec-cli/$VERSION",
        timeout => 120,
    );
}

sub _handle_response {
    my ($res) = @_;

    # HTTP::Tiny sets success=0 and status=599 for connection errors
    if ($res->{status} == 599) {
        die "Connection error: $res->{content}\n";
    }

    my $body = $res->{content} // '';
    unless ($body =~ /\S/) {
        die "Empty response from server (HTTP $res->{status})\n";
    }

    my $data = eval { decode_json($body) };
    die "Invalid JSON response (HTTP $res->{status}): $body\n" if $@;

    return $data;
}

# ---------------------------------------------------------------------------
# Config and context
# ---------------------------------------------------------------------------

sub load_config {
    my ($path) = @_;
    my %cfg;
    return \%cfg unless -f $path;
    open my $fh, '<', $path or return \%cfg;
    while (<$fh>) {
        chomp;
        next if /^\s*#/ || /^\s*$/;
        $cfg{$1} = $2 if /^\s*([\w_]+)\s*=\s*(.+?)\s*$/;
    }
    close $fh;
    return \%cfg;
}

sub build_context {
    my ($opts, $cfg) = @_;

    # Priority: flag > env > config file > default
    my $url = $opts->{url}
        // $ENV{CTRL_EXEC_API_URL}
        // $cfg->{url}
        // $DEFAULT_URL;
    $url =~ s{/+$}{};

    return {
        url      => $url,
        token    => $opts->{token}    // $ENV{CTRL_EXEC_TOKEN}    // $cfg->{token}    // '',
        username => $opts->{username} // $ENV{CTRL_EXEC_USERNAME} // $cfg->{username} // $ENV{USER} // '',
        json     => $opts->{json} // 0,
    };
}

# ---------------------------------------------------------------------------
# Error helper
# ---------------------------------------------------------------------------

sub die_error {
    my ($data) = @_;
    my $msg = $data->{error} // 'unknown error';
    $msg .= ": $data->{detail}" if $data->{detail};
    die "Error: $msg\n";
}

# ---------------------------------------------------------------------------
# Usage
# ---------------------------------------------------------------------------

sub usage_main { return <<'END';
ctrl-exec-cli - CLI client for the ctrl-exec HTTP API

Usage:
  ctrl-exec-cli [global options] <command> [command options] [args]

Commands:
  health                      Check API server liveness and version
  ping    <host> [host...]    Test mTLS connectivity to one or more agents
  run     <host> [host...]    Run an allowlisted script on one or more agents
  status  <reqid>             Retrieve the stored result for a completed run
  discovery [host...]         List registered agents and their scripts

Global options:
  --url <url>         API base URL (default: http://localhost:7445)
  --token <token>     Auth token (overrides CTRL_EXEC_TOKEN)
  --username <name>   Username (overrides CTRL_EXEC_USERNAME, default: $USER)
  --json              Raw JSON output (applies to all commands)
  --version           Print version and exit
  --help              Print this help and exit

Config file (~/.ctrl-exec-cli.conf):
  url      = http://myhost:7445
  token    = mytoken
  username = alice

Priority: flag > environment variable > config file > default

Environment variables:
  CTRL_EXEC_API_URL    API base URL
  CTRL_EXEC_TOKEN      Auth token
  CTRL_EXEC_USERNAME   Username

Run 'ctrl-exec-cli <command> --help' for command-specific help.
END
}

sub usage_health { return <<'END';
Usage: ctrl-exec-cli health [--json]

Check API server liveness and version. No authentication required.

  --json    Raw JSON output

Examples:
  ctrl-exec-cli health
  ctrl-exec-cli health --json
END
}

sub usage_ping { return <<'END';
Usage: ctrl-exec-cli ping [--json] <host> [host...]

  <host>    Agent hostname or hostname:port (port defaults to 7443)
  --json    Raw JSON output

Output columns: HOST  STATUS  RTT  CERT EXPIRY  VERSION

Examples:
  ctrl-exec-cli ping web-01
  ctrl-exec-cli ping web-01 web-02 db-01
  ctrl-exec-cli ping web-01:7450
  ctrl-exec-cli ping web-01 --json
END
}

sub usage_run { return <<'END';
Usage: ctrl-exec-cli run [--async] [--json] <host> [host...] --script <n> [-- arg...]

  <host>           One or more agent hostnames (hostname or hostname:port)
  --script <n>  Allowlisted script name (required)
  --async          Submit and print reqid immediately; do not wait for results
  --json           Raw JSON output
  --               Everything after -- is passed to the script as arguments

Without --async, blocks until all hosts complete and prints full results.
With --async, prints only the reqid (one line) and exits 0. Use
'ctrl-exec-cli status <reqid>' to retrieve the result later.

Exit codes (synchronous):
  0   All hosts succeeded (script exit 0 on all)
  1   One or more hosts failed, or dispatcher-side error

Examples:
  ctrl-exec-cli run web-01 --script deploy
  ctrl-exec-cli run db-01 db-02 --script backup-mysql -- --database myapp
  ctrl-exec-cli run web-01 web-02 --script check-disk --json
  ctrl-exec-cli run db-01 --script pg-vacuum -- --full --analyse
  ctrl-exec-cli run db-01 --script long-job --async
  REQID=\$(ctrl-exec-cli run db-01 --script long-job --async)
  ctrl-exec-cli status \$REQID
END
}

sub usage_status { return <<'END';
Usage: ctrl-exec-cli status [--json] <reqid>

  <reqid>   Request ID returned by a previous run
  --json    Raw JSON output

Results are retained for 24 hours after the run completes. A 404 means the
reqid is unknown, has expired, or predates result persistence.

Output: reqid, script, hosts, completed timestamp, then per-host results
in the same format as 'run'.

Examples:
  ctrl-exec-cli status a1b2c3d4
  ctrl-exec-cli status a1b2c3d4 --json
  ctrl-exec-cli status \$(ctrl-exec-cli run db-01 --script backup --async)
END
}

sub usage_discovery { return <<'END';
Usage: ctrl-exec-cli discovery [--scripts] [--json] [host...]

  [host...]   Hostnames to filter results (default: all registered agents)
  --scripts   Show scripts for each host (verbose)
  --json      Raw JSON output

Output (default):  HOST  STATUS  VERSION  SCRIPTS (count)
Output (--scripts): one block per host with script names and paths

Examples:
  ctrl-exec-cli discovery
  ctrl-exec-cli discovery --scripts
  ctrl-exec-cli discovery web-01 db-01
  ctrl-exec-cli discovery --scripts web-01
  ctrl-exec-cli discovery --json
END
}
